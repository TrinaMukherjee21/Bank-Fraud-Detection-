# Environment Variables for Bank Fraud Detection System
# Copy this file to .env and update the values for production

# Database Configuration
# Supported types: sqlite, mysql, postgresql
DB_TYPE=sqlite
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fraud_detection
DB_USER=fraud_user
DB_PASSWORD=secure_password_here
DB_SQLITE_FILE=fraud_detection.db

# Database Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Flask Configuration
SECRET_KEY=your-very-secure-secret-key-change-in-production
FLASK_DEBUG=False
HOST=127.0.0.1
PORT=5000

# Security Settings
# Rate limiting
RATELIMIT_STORAGE_URL=memory://

# Data Retention Settings (in days)
DATA_RETENTION_DAYS=90

# Model Configuration
MODEL_PATH=model/fraud_model.pkl
ENCODERS_PATH=model/label_encoders.pkl
THRESHOLD_PATH=model/threshold.pkl

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=fraud_detection.log

# Monitoring and Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Production Database Examples:

# MySQL Production Configuration
# DB_TYPE=mysql
# DB_HOST=your-mysql-server.com
# DB_PORT=3306
# DB_NAME=fraud_detection_prod
# DB_USER=fraud_user
# DB_PASSWORD=your-secure-database-password
# DB_POOL_SIZE=50
# DB_MAX_OVERFLOW=100

# PostgreSQL Production Configuration
# DB_TYPE=postgresql
# DB_HOST=your-postgres-server.com
# DB_PORT=5432
# DB_NAME=fraud_detection_prod
# DB_USER=fraud_user
# DB_PASSWORD=your-secure-database-password
# DB_POOL_SIZE=50
# DB_MAX_OVERFLOW=100

# Cloud Database Examples:

# AWS RDS MySQL
# DB_TYPE=mysql
# DB_HOST=fraud-detection.cluster-xyz.us-east-1.rds.amazonaws.com
# DB_PORT=3306
# DB_NAME=fraud_detection
# DB_USER=admin
# DB_PASSWORD=your-aws-rds-password

# Google Cloud SQL
# DB_TYPE=mysql
# DB_HOST=/cloudsql/your-project:us-central1:fraud-detection
# DB_NAME=fraud_detection
# DB_USER=fraud_user
# DB_PASSWORD=your-gcp-sql-password

# Azure Database for MySQL
# DB_TYPE=mysql
# DB_HOST=fraud-detection.mysql.database.azure.com
# DB_PORT=3306
# DB_NAME=fraud_detection
# DB_USER=admin@fraud-detection
# DB_PASSWORD=your-azure-mysql-password